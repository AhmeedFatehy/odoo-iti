<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_hms_doctor_list" model="ir.ui.view">
        <field name="name">hms.doctor.list</field>
        <field name="model">hms.doctor</field>
        <field name="arch" type="xml">
            <list string="Doctors">
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="image" widget="image"/>
            </list>
        </field>
    </record>

    <record id="view_hms_doctor_form" model="ir.ui.view">
        <field name="name">hms.doctor.form</field>
        <field name="model">hms.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                        </group>
                        <group>
                            <field name="image" widget="image" options="{'size': [50, 50]}"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hms_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hms.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hms_doctor"
              name="Doctors"
              parent="menu_hms_root"
              action="action_hms_doctor"
              sequence="2"
              groups="hms.group_hms_manager"/>

</odoo>