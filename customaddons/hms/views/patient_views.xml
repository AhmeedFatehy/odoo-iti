<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hms_patient_list" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <list string="Patients">
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="age"/>
                <field name="blood_type"/>
                <field name="pcr"/>
                <field name="cr_ratio" required="pcr"/>
                <field name="department_id"/>
                <field name="department_capacity" readonly="1"/>
                <field name="doctor_ids" widget="many2many_tags"/>
                <field name="state"/>
                <field name="history" invisible="age > 50"/>
                <field name="email" widget="email"/>
            </list>
        </field>
    </record>

    <record id="view_hms_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
            <header>
                <button name="%(action_report_patient_status)d"
                        string="Print Report"
                        type="action"
                        class="btn-primary"/>
            </header>
                <sheet>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="birth_date"/>
                            <field name="age" readonly="1"/>
                            <field name="blood_type"/>
                            <field name="pcr"/>
                            <field name="cr_ratio"/>
                            <field name="department_id"/>
                            <field name="department_capacity" readonly="1"/>
                            <field name="doctor_ids" widget="many2many_tags" readonly="not department_id" groups="hms.group_hms_manager"/>
                            <field name="state"/>
                            <field name="email" widget="email"/>

                        </group>

                        <group>
                            <field name="image" widget="image"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="History">
                            <field name="history"/>
                        </page>

                        <page string="Address">
                            <field name="address"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hms_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hms_root"
              name="HMS"
              sequence="1"/>

    <menuitem id="menu_hms_patient"
              name="Patients"
              parent="menu_hms_root"
              action="action_hms_patient"
              sequence="1"/>

</odoo>