<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <record id="module_category_hms" model="ir.module.category">
            <field name="name">Hospital Management System</field>
            <field name="description">Helps manage patients, doctors, and departments.</field>
            <field name="sequence">10</field>
        </record>

        <record id="res_groups_privilege_hms" model="res.groups.privilege">
            <field name="name">HMS Access</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="hms.module_category_hms"/>
        </record>

        <record id="group_hms_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="hms.res_groups_privilege_hms"/>
        </record>

        <record id="group_hms_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="sequence">20</field>
            <field name="implied_ids" eval="[(4, ref('hms.group_hms_user'))]"/>
            <field name="privilege_id" ref="hms.res_groups_privilege_hms"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>

    <data noupdate="1">
        
        <record id="rule_patient_user_own" model="ir.rule">
            <field name="name">User Own Patients</field>
            <field name="model_id" ref="model_hms_patient"/>
            <field name="domain_force">[('created_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('hms.group_hms_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_patient_manager_all" model="ir.rule">
            <field name="name">Manager All Patients</field>
            <field name="model_id" ref="model_hms_patient"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hms.group_hms_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

    </data>
</odoo>